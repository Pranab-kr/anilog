# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Better Auth
BETTER_AUTH_SECRET=your-secret-key
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# UploadThing - Get your keys from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your-uploadthing-token

# AniList (optional) - Register an app at https://anilist.co/settings/developer
# Redirect URI to set there: http://localhost:3000/api/anilist/callback
ANILIST_CLIENT_ID=your-anilist-client-id
ANILIST_CLIENT_SECRET=your-anilist-client-secret
# Optional override (defaults to ${BETTER_AUTH_URL}/api/anilist/callback)
# ANILIST_REDIRECT_URI=http://localhost:3000/api/anilist/callback

# Inngest background jobs
# Local development: run `INNGEST_DEV=1 bun run dev` and `bunx inngest-cli@latest dev`
INNGEST_DEV=1
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
